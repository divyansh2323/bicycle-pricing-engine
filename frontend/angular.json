{
  "$schema": "https://angular.io/config/application",
  "version": 1,
  "projects": {
    "bicycle-pricing-frontend": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/bicycle-pricing-frontend",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [
                "zone.js"
            ],
            "tsConfig": "tsconfig.json",
            "assets": ["src/assets"],
            "styles": ["src/styles.css"],
            "scripts": []
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "bicycle-pricing-frontend:build"
          }
        }
      }
    }
  },
  "defaultProject": "bicycle-pricing-frontend",
  "cli": {
    "analytics": false
  }
}
